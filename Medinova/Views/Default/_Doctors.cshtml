@model List<Medinova.Models.Doctor>
@{
    bool hasDoctors = Model != null && Model.Count > 0;
}
<div class="container-fluid py-5" id="doctors">
    <div class="container">
        <div class="text-center mx-auto mb-5" style="max-width:500px;">
            <h5 class="d-inline-block text-primary text-uppercase border-bottom border-5">Doktorlarimiz</h5>
            <h1 class="display-4">Uzman Saglik Profesyonelleri</h1>
        </div>
        @if (hasDoctors)
        {
            <div class="owl-carousel team-carousel position-relative">
                @foreach (var doctor in Model)
                {
                    <div class="team-item">
                        <div class="row g-0 bg-light rounded overflow-hidden">
                            <div class="col-12 col-sm-5 h-100">
                                @if (!string.IsNullOrWhiteSpace(doctor.Image))
                                {
                                    <img class="img-fluid h-100" src="@doctor.Image"
                                         style="object-fit:cover; min-height:200px;">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center bg-primary"
                                         style="min-height:200px; height:100%;">
                                        <i class="fas fa-user-md fa-4x text-white"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-12 col-sm-7 h-100 d-flex flex-column">
                                <div class="mt-auto p-4">
                                    <h3>@doctor.FullName</h3>
                                    @if (doctor.Department != null && !string.IsNullOrWhiteSpace(doctor.Department.Name))
                                    {
                                        <h6 class="fw-normal fst-italic text-primary mb-3">@doctor.Department.Name Uzmani</h6>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(doctor.Description))
                                    {
                                        <p class="m-0">@doctor.Description</p>
                                    }
                                </div>
                                <div class="d-flex mt-auto border-top p-4">
                                    <a href="#appointment" class="btn btn-primary rounded-pill py-2 px-4">
                                        <i class="fa fa-calendar-check me-2"></i>Randevu Al
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-user-md fa-4x text-muted mb-3"></i>
                <p class="text-muted">Henuz doktor eklenmemistir.</p>
            </div>
        }
    </div>
</div>