@model List<Medinova.Models.Testimonial>
@{
    bool hasData = Model != null && Model.Count > 0;
}
@if (hasData)
{
    <div class="container-fluid py-5">
        <div class="container">
            <div class="text-center mx-auto mb-5" style="max-width:500px;">
                <h5 class="d-inline-block text-primary text-uppercase border-bottom border-5">Testimonial</h5>
                <h1 class="display-4">Patients Say About Our Services</h1>
            </div>
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="owl-carousel testimonial-carousel">
                        @foreach (var item in Model)
                        {
                            <div class="testimonial-item text-center">
                                <div class="position-relative mb-5">
                                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img class="img-fluid rounded-circle mx-auto"
                                             src="@item.ImageUrl" alt="@item.FullName"
                                             style="width:100px; height:100px; object-fit:cover;">
                                    }
                                    else
                                    {
                                        <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center bg-primary"
                                             style="width:100px; height:100px;">
                                            <i class="fas fa-user fa-3x text-white"></i>
                                        </div>
                                    }
                                    <div class="position-absolute top-100 start-50 translate-middle
                                                d-flex align-items-center justify-content-center
                                                bg-white rounded-circle"
                                         style="width:60px; height:60px;">
                                        <i class="fa fa-quote-left fa-2x text-primary"></i>
                                    </div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.Comment))
                                {
                                    <p class="fs-4 fw-normal">@item.Comment</p>
                                }
                                <hr class="w-25 mx-auto">
                                <h3>@item.FullName</h3>
                                @if (!string.IsNullOrWhiteSpace(item.Title))
                                {
                                    <h6 class="fw-normal text-primary mb-3">@item.Title</h6>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
