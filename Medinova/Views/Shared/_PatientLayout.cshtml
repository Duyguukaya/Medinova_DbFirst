@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Medinova - Hasta Paneli</title>

    <link href="~/Templates/startbootstrap-sb-admin-2-gh-pages/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="~/Templates/startbootstrap-sb-admin-2-gh-pages/css/sb-admin-2.min.css" rel="stylesheet">

    <style>
        .sidebar-patient {
            background: linear-gradient(180deg, #1a3a6b 0%, #142d5c 50%, #0e2045 100%) !important;
        }

        .sidebar-brand-patient {
            background: rgba(0,0,0,0.15);
            padding: 1.5rem 1rem;
            margin-bottom: 0.5rem;
        }

            .sidebar-brand-patient .brand-icon {
                width: 48px;
                height: 48px;
                background: rgba(255,255,255,0.15);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 8px;
            }

                .sidebar-brand-patient .brand-icon i {
                    font-size: 1.4rem;
                    color: #fff;
                }

            .sidebar-brand-patient .brand-name {
                color: #fff;
                font-size: 1rem;
                font-weight: 700;
                letter-spacing: 1px;
                text-align: center;
                display: block;
            }

            .sidebar-brand-patient .brand-sub {
                color: rgba(255,255,255,0.6);
                font-size: 0.7rem;
                text-align: center;
                display: block;
                letter-spacing: 2px;
                text-transform: uppercase;
            }

        .patient-nav-item .nav-link {
            color: rgba(255,255,255,0.75) !important;
            padding: 0.85rem 1rem !important;
            border-radius: 0;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

            .patient-nav-item .nav-link:hover {
                color: #fff !important;
                background: rgba(255,255,255,0.1) !important;
                border-left-color: #5b8dee !important;
            }

            .patient-nav-item .nav-link.active {
                color: #fff !important;
                background: rgba(255,255,255,0.15) !important;
                border-left-color: #5b8dee !important;
            }

            .patient-nav-item .nav-link i {
                color: rgba(255,255,255,0.5);
                width: 1.25rem;
                margin-right: 0.5rem;
            }

            .patient-nav-item .nav-link:hover i, .patient-nav-item .nav-link.active i {
                color: #5b8dee;
            }

        .sidebar-section-title {
            color: rgba(255,255,255,0.4);
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.1rem;
            text-transform: uppercase;
            padding: 1rem 1rem 0.3rem;
        }

        .sidebar-divider-patient {
            border-top: 1px solid rgba(255,255,255,0.1);
            margin: 0.5rem 0;
        }

        .topbar-patient {
            border-bottom: 2px solid #1a3a6b;
        }

        .profile-circle-patient {
            width: 36px;
            height: 36px;
            background: #1a3a6b;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .footer-patient {
            border-top: 2px solid #e8eef8;
        }

        .alert {
            border-radius: 8px;
        }
    </style>
</head>

<body id="page-top">
    <div id="wrapper">

        <!-- Sidebar -->
        <ul class="navbar-nav sidebar sidebar-dark accordion sidebar-patient" id="accordionSidebar" style="min-height:100vh;">

            <!-- Brand -->
            <div class="sidebar-brand-patient text-center">
                <div class="brand-icon mx-auto">
                    <i class="fas fa-user"></i>
                </div>
                <span class="brand-name">MEDINOVA</span>
                <span class="brand-sub">Hasta Paneli</span>
            </div>

            <hr class="sidebar-divider-patient">

            <div class="sidebar-section-title">Ana Ekran</div>
            <li class="nav-item patient-nav-item">
                <a class="nav-link" href="/Patient/PatientPanel/Index">
                    <i class="fas fa-fw fa-calendar-alt"></i>
                    <span>Randevularim</span>
                </a>
            </li>

            <hr class="sidebar-divider-patient">

            <div class="sidebar-section-title">Islemler</div>
            <li class="nav-item patient-nav-item">
                <a class="nav-link" href="/Patient/PatientPanel/NewAppointment">
                    <i class="fas fa-fw fa-calendar-plus"></i>
                    <span>Yeni Randevu Al</span>
                </a>
            </li>

            <hr class="sidebar-divider-patient">

            <div class="sidebar-section-title">Hesap</div>
            <li class="nav-item patient-nav-item">
                <a class="nav-link" href="/Account/Logout">
                    <i class="fas fa-fw fa-sign-out-alt"></i>
                    <span>Cikis Yap</span>
                </a>
            </li>

            <hr class="sidebar-divider-patient d-none d-md-block">
            <div class="text-center d-none d-md-inline mt-2 mb-3">
                <button class="rounded-circle border-0" id="sidebarToggle" style="background:rgba(255,255,255,0.1);width:2rem;height:2rem;"></button>
            </div>

        </ul>
        <!-- End Sidebar -->

        <div id="content-wrapper" class="d-flex flex-column" style="background:#f4f6fb;">
            <div id="content">

                <!-- Topbar -->
                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow-sm topbar-patient">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars" style="color:#1a3a6b;"></i>
                    </button>

                    <div class="d-none d-sm-flex align-items-center">
                        <div style="width:6px;height:6px;border-radius:50%;background:#1a3a6b;margin-right:8px;"></div>
                        <span style="font-size:0.8rem;color:#888;">Aktif Oturum</span>
                    </div>

                    <ul class="navbar-nav ml-auto align-items-center">

                        <li class="nav-item mr-3 d-none d-lg-block">
                            <a href="/Patient/PatientPanel/NewAppointment" class="btn btn-sm" style="background:#eef2fb;color:#1a3a6b;border:1px solid #c5d3f0;font-size:0.75rem;">
                                <i class="fas fa-calendar-plus mr-1"></i>Yeni Randevu Al
                            </a>
                        </li>

                        <div style="width:1px;height:2rem;background:#e0e0e0;" class="mr-3 d-none d-lg-block"></div>

                        <!-- Kullanici dropdown -->
                        <li class="nav-item dropdown no-arrow">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <div class="d-none d-lg-block mr-2 text-right">
                                    <div style="font-size:0.85rem;font-weight:600;color:#333;">@Session["fullName"]</div>
                                    <div style="font-size:0.7rem;color:#1a3a6b;">Hasta</div>
                                </div>
                                <div class="profile-circle-patient">
                                    @{
                                        var fn = Session["fullName"] as string;
                                        string initials = "HT";
                                        if (!string.IsNullOrEmpty(fn))
                                        {
                                            var parts = fn.Split(' ');
                                            initials = parts.Length >= 2
                                                ? (parts[0].Length > 0 ? parts[0][0].ToString() : "") + (parts[parts.Length - 1].Length > 0 ? parts[parts.Length - 1][0].ToString() : "")
                                                : (fn.Length > 0 ? fn[0].ToString() : "HT");
                                        }
                                    }
                                    @initials
                                </div>
                            </a>
                            <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in" aria-labelledby="userDropdown">
                                <div class="dropdown-header" style="background:#f8f9ff;border-bottom:1px solid #e8eef8;">
                                    <div style="font-weight:700;color:#1a3a6b;">@Session["fullName"]</div>
                                    <div style="font-size:0.75rem;color:#888;">Hasta Hesabi</div>
                                </div>
                                <a class="dropdown-item" href="/Patient/PatientPanel/Index">
                                    <i class="fas fa-calendar-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                                    Randevularim
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item text-danger" href="/Account/Logout">
                                    <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2"></i>
                                    Cikis Yap
                                </a>
                            </div>
                        </li>
                    </ul>
                </nav>
                <!-- End Topbar -->
                <!-- Bildirimler -->
                <div class="container-fluid">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                            <i class="fas fa-check-circle mr-2"></i>@TempData["Success"]
                            <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                            <i class="fas fa-exclamation-circle mr-2"></i>@TempData["Error"]
                            <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        </div>
                    }
                    @RenderBody()
                </div>

            </div>

            <footer class="sticky-footer bg-white footer-patient">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span style="color:#888;font-size:0.8rem;">
                            <i class="fas fa-heart mr-1" style="color:#1a3a6b;"></i>
                            Copyright &copy; Medinova @DateTime.Now.Year &mdash; Hasta Paneli
                        </span>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    <script src="~/Templates/startbootstrap-sb-admin-2-gh-pages/vendor/jquery/jquery.min.js"></script>
    <script src="~/Templates/startbootstrap-sb-admin-2-gh-pages/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Templates/startbootstrap-sb-admin-2-gh-pages/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="~/Templates/startbootstrap-sb-admin-2-gh-pages/js/sb-admin-2.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>