@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>MEDINOVA - Hastane</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="Medinova Hastanesi, saglik, doktor, randevu" name="keywords">
    <meta content="Medinova Hastanesi resmi web sitesi" name="description">
    <link href="~/Templates/Medinova-1.0.0/img/favicon.ico" rel="icon">
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Templates/Medinova-1.0.0/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/Templates/Medinova-1.0.0/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />
    <link href="~/Templates/Medinova-1.0.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Templates/Medinova-1.0.0/css/style.css" rel="stylesheet">
</head>
<body>

    <!-- Üst Bilgi Çubuğu -->
    <div class="container-fluid py-2 border-bottom d-none d-lg-block">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-lg-start mb-2 mb-lg-0">
                    <div class="d-inline-flex align-items-center">
                        <a class="text-decoration-none text-body pe-3" href="#!">
                            <i class="bi bi-telephone me-2"></i>+90 212 345 67 89
                        </a>
                        <span class="text-body">|</span>
                        <a class="text-decoration-none text-body px-3" href="#!">
                            <i class="bi bi-envelope me-2"></i>info@medinova.com.tr
                        </a>
                    </div>
                </div>
                <div class="col-md-6 text-center text-lg-end">
                    <div class="d-inline-flex align-items-center">
                        <a class="text-body px-2" href="#!"><i class="fab fa-facebook-f"></i></a>
                        <a class="text-body px-2" href="#!"><i class="fab fa-twitter"></i></a>
                        <a class="text-body px-2" href="#!"><i class="fab fa-linkedin-in"></i></a>
                        <a class="text-body px-2" href="#!"><i class="fab fa-instagram"></i></a>
                        <a class="text-body ps-2" href="#!"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Navbar -->
    <div class="container-fluid sticky-top bg-white shadow-sm">
        <div class="container">
            <nav class="navbar navbar-expand-lg bg-white navbar-light py-3 py-lg-0">
                <a href="/Default/Index" class="navbar-brand">
                    <h1 class="m-0 text-uppercase text-primary"><i class="fa fa-clinic-medical me-2"></i>Medinova</h1>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <div class="navbar-nav ms-auto py-0">
                        <a href="/Default/Index" class="nav-item nav-link active">Ana Sayfa</a>
                        <a href="#about" class="nav-item nav-link">Hakkimizda</a>
                        <a href="#doctors" class="nav-item nav-link">Doktorlar</a>
                        <a href="#appointment" class="nav-item nav-link">Randevu Al</a>
                        <a href="/Account/Login" class="nav-item nav-link">
                            <i class="fa fa-sign-in-alt me-1"></i>Giris Yap
                        </a>
                    </div>
                </div>
            </nav>
        </div>
    </div>

    @RenderBody()

    <!-- Footer -->
    <div class="container-fluid bg-dark text-light mt-5 py-5">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-3 col-md-6">
                    <h4 class="d-inline-block text-primary text-uppercase border-bottom border-5 border-secondary mb-4">
                        Iletisim
                    </h4>
                    <p class="mb-4">Sagliginiz icin her zaman yaninizdayiz. Bize ulasmaktan cekinmeyin.</p>
                    <p class="mb-2"><i class="fa fa-map-marker-alt text-primary me-3"></i>Ataturk Cad. No:1, Istanbul</p>
                    <p class="mb-2"><i class="fa fa-envelope text-primary me-3"></i>info@medinova.com.tr</p>
                    <p class="mb-0"><i class="fa fa-phone-alt text-primary me-3"></i>+90 212 345 67 89</p>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="d-inline-block text-primary text-uppercase border-bottom border-5 border-secondary mb-4">
                        Hizli Erisim
                    </h4>
                    <div class="d-flex flex-column justify-content-start">
                        <a class="text-light mb-2" href="/Default/Index"><i class="fa fa-angle-right me-2"></i>Ana Sayfa</a>
                        <a class="text-light mb-2" href="#about"><i class="fa fa-angle-right me-2"></i>Hakkimizda</a>
                        <a class="text-light mb-2" href="#doctors"><i class="fa fa-angle-right me-2"></i>Doktorlarimiz</a>
                        <a class="text-light mb-2" href="#appointment"><i class="fa fa-angle-right me-2"></i>Randevu Al</a>
                        <a class="text-light" href="/Account/Login"><i class="fa fa-angle-right me-2"></i>Hasta Girisi</a>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="d-inline-block text-primary text-uppercase border-bottom border-5 border-secondary mb-4">
                        Calisma Saatleri
                    </h4>
                    <div class="d-flex flex-column">
                        <p class="text-light mb-2"><i class="fa fa-clock text-primary me-3"></i>Pazartesi - Cuma: 08:00 - 18:00</p>
                        <p class="text-light mb-2"><i class="fa fa-clock text-primary me-3"></i>Cumartesi: 09:00 - 14:00</p>
                        <p class="text-light mb-2"><i class="fa fa-clock text-primary me-3"></i>Pazar: Kapali</p>
                        <p class="text-light mb-0"><i class="fa fa-ambulance text-primary me-3"></i>Acil: 7/24 Acik</p>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="d-inline-block text-primary text-uppercase border-bottom border-5 border-secondary mb-4">
                        Bultene Abone Ol
                    </h4>
                    <form action="">
                        <div class="input-group">
                            <input type="email" class="form-control p-3 border-0" placeholder="E-posta Adresiniz">
                            <button class="btn btn-primary" type="submit">Abone Ol</button>
                        </div>
                    </form>
                    <h6 class="text-primary text-uppercase mt-4 mb-3">Bizi Takip Edin</h6>
                    <div class="d-flex">
                        <a class="btn btn-lg btn-primary btn-lg-square rounded-circle me-2" href="#!"><i class="fab fa-twitter"></i></a>
                        <a class="btn btn-lg btn-primary btn-lg-square rounded-circle me-2" href="#!"><i class="fab fa-facebook-f"></i></a>
                        <a class="btn btn-lg btn-primary btn-lg-square rounded-circle me-2" href="#!"><i class="fab fa-linkedin-in"></i></a>
                        <a class="btn btn-lg btn-primary btn-lg-square rounded-circle" href="#!"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid bg-dark text-light border-top border-secondary py-4">
        <div class="container">
            <div class="row g-5">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-md-0">&copy; <a class="text-primary" href="#!">Medinova Hastanesi</a>. Tum Haklari Saklidir.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="mb-0">Medinova &copy; @DateTime.Now.Year</p>
                </div>
            </div>
        </div>
    </div>

    <a href="#!" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Templates/Medinova-1.0.0/lib/easing/easing.min.js"></script>
    <script src="~/Templates/Medinova-1.0.0/lib/waypoints/waypoints.min.js"></script>
    <script src="~/Templates/Medinova-1.0.0/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/Templates/Medinova-1.0.0/lib/tempusdominus/js/moment.min.js"></script>
    <script src="~/Templates/Medinova-1.0.0/lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="~/Templates/Medinova-1.0.0/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/Templates/Medinova-1.0.0/js/main.js"></script>
</body>
</html>