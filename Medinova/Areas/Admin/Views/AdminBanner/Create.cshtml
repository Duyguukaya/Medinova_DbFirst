@model Medinova.Models.Banner
@{
    ViewBag.Title = "Banner Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Yeni Banner Ekle</h1>
    <a href="/Admin/AdminBanner/Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left mr-1"></i>Geri</a>
</div>
<div class="card shadow mb-4">
    <div class="card-body">
        @using (Html.BeginForm("Create", "AdminBanner", FormMethod.Post))
        {
            <div class="form-group">
                <label>Başlık</label>
                @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Açıklama</label>
                @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "3" })
            </div>
            <div class="form-group">
                <label>Görsel URL</label>
                @Html.TextBoxFor(m => m.ImageUrl, new { @class = "form-control" })
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save mr-1"></i>Kaydet</button>
            <a href="/Admin/AdminBanner/Index" class="btn btn-secondary ml-2">İptal</a>
        }
    </div>
</div>