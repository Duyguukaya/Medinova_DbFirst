@model Medinova.Models.About
@{
    ViewBag.Title = "Hakkımızda Sil";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Hakkımızda Sil</h1>
    <a href="/Admin/AdminAbout/Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left mr-1"></i>Geri</a>
</div>
<div class="card shadow mb-4">
    <div class="card-body">
        <div class="alert alert-danger"><strong>Dikkat!</strong> Bu kaydı silmek istediğinizden emin misiniz?</div>
        <dl class="row">
            <dt class="col-sm-3">Başlık</dt><dd class="col-sm-9">@Model.Title</dd>
            <dt class="col-sm-3">Açıklama</dt><dd class="col-sm-9">@Model.Description</dd>
        </dl>
        @using (Html.BeginForm("Delete", "AdminAbout", new { id = Model.AboutId }, FormMethod.Post))
        {
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash mr-1"></i>Evet, Sil</button>
            <a href="/Admin/AdminAbout/Index" class="btn btn-secondary ml-2">İptal</a>
        }
    </div>
</div>