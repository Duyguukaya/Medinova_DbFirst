@model List<Medinova.Models.Department>
@{
    ViewBag.Title = "Bölümler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Bölümler</h1>
    <a href="/Admin/AdminDepartment/Create" class="btn btn-primary btn-sm shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i> Yeni Bölüm Ekle
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="thead-dark">
                    <tr>
                        <th>#</th>
                        <th>Bölüm Adı</th>
                        <th>Doktor Sayısı</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@item.Name</td>
                            <td>@(item.Doctors != null ? item.Doctors.Count : 0)</td>
                            <td>
                                <a href="/Admin/AdminDepartment/Edit/@item.DepartmentId" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                <a href="/Admin/AdminDepartment/Delete/@item.DepartmentId" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>