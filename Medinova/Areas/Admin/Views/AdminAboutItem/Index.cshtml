@model List<Medinova.Models.AboutItem>
@{
    ViewBag.Title = "Hakkımızda Maddeleri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Hakkımızda Maddeleri</h1>
    <a href="/Admin/AdminAboutItem/Create" class="btn btn-primary btn-sm"><i class="fas fa-plus fa-sm text-white-50"></i> Yeni Ekle</a>
</div>
<div class="card shadow mb-4">
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead class="thead-dark">
                <tr><th>#</th><th>İkon</th><th>Ad</th><th>İşlemler</th></tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td><i class="@item.Icon"></i> <small class="text-muted">@item.Icon</small></td>
                        <td>@item.Name</td>
                        <td>
                            <a href="/Admin/AdminAboutItem/Edit/@item.AboutItemId" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                            <a href="/Admin/AdminAboutItem/Delete/@item.AboutItemId" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>
    </div>
</div>