@model Medinova.Models.AboutItem
@{
    ViewBag.Title = "Madde Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Madde Düzenle</h1>
    <a href="/Admin/AdminAboutItem/Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left mr-1"></i>Geri</a>
</div>
<div class="card shadow mb-4">
    <div class="card-body">
        @using (Html.BeginForm("Edit", "AdminAboutItem", FormMethod.Post))
        {
            @Html.HiddenFor(m => m.AboutItemId)
            <div class="form-group">
                <label>İkon CSS Sınıfı</label>
                @Html.TextBoxFor(m => m.Icon, new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Madde Adı</label>
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
            </div>
            <button type="submit" class="btn btn-warning"><i class="fas fa-save mr-1"></i>Güncelle</button>
            <a href="/Admin/AdminAboutItem/Index" class="btn btn-secondary ml-2">İptal</a>
        }
    </div>
</div>