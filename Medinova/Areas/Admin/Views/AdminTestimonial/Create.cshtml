@model Medinova.Models.Testimonial
@{
    ViewBag.Title = "Referans Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Yeni Referans Ekle</h1>
    <a href="/Admin/AdminTestimonial/Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left mr-1"></i>Geri</a>
</div>
<div class="card shadow mb-4">
    <div class="card-body">
        @using (Html.BeginForm("Create", "AdminTestimonial", FormMethod.Post))
        {
            <div class="form-group">
                <label>Ad Soyad</label>
                @Html.TextBoxFor(m => m.FullName, new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Unvan</label>
                @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Görsel URL</label>
                @Html.TextBoxFor(m => m.ImageUrl, new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Yorum</label>
                @Html.TextAreaFor(m => m.Comment, new { @class = "form-control", rows = "4" })
            </div>
            <div class="form-group">
                <label>Onay Durumu</label>
                <select name="IsApproved" class="form-control">
                    <option value="true">Onaylı</option>
                    <option value="false" selected="selected">Beklemede</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save mr-1"></i>Kaydet</button>
            <a href="/Admin/AdminTestimonial/Index" class="btn btn-secondary ml-2">İptal</a>
        }
    </div>
</div>