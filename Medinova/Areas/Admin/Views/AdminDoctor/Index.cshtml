@model List<Medinova.Models.Doctor>
@{
    ViewBag.Title = "Doktorlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Doktorlar</h1>
    <a href="/Admin/AdminDoctor/Create" class="btn btn-primary btn-sm shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i> Yeni Doktor Ekle
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="thead-dark">
                    <tr>
                        <th>#</th>
                        <th>Ad Soyad</th>
                        <th>Bölüm</th>
                        <th>Açıklama</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Image))
                                {
                                    <img src="@item.Image" style="width:35px;height:35px;border-radius:50%;object-fit:cover;" class="mr-2" />
                                }
                                @item.FullName
                            </td>
                            <td>@(item.Department != null ? item.Department.Name : "-")</td>
                            <td>@(item.Description != null && item.Description.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)</td>
                            <td>
                                <a href="/Admin/AdminDoctor/Appointments/@item.DoctorId" class="btn btn-info btn-sm" title="Randevuları Gör">
                                    <i class="fas fa-calendar-alt"></i>
                                </a>
                                <a href="/Admin/AdminDoctor/Edit/@item.DoctorId" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="/Admin/AdminDoctor/Delete/@item.DoctorId" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>