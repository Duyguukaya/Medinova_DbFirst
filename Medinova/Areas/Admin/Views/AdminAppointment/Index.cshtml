@model List<Medinova.Models.Appointment>
@{
    ViewBag.Title = "Randevular";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Tüm Randevular</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="thead-dark">
                    <tr>
                        <th>#</th>
                        <th>Hasta</th>
                        <th>Doktor</th>
                        <th>Tarih</th>
                        <th>Saat</th>
                        <th>Telefon</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@item.FullName</td>
                            <td>@(item.Doctor != null ? item.Doctor.FullName : "-")</td>
                            <td>@(item.AppointmentDate.HasValue ? item.AppointmentDate.Value.ToString("dd.MM.yyyy") : "-")</td>
                            <td>@item.AppointmentTime</td>
                            <td>@item.PhoneNumber</td>
                            <td>
                                @if (item.IsActive == true)
                                {
                                    <span class="badge badge-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Pasif</span>
                                }
                            </td>
                            <td>
                                @using (Html.BeginForm("ToggleStatus", "AdminAppointment", new { id = item.Appointmentid }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    <button type="submit" class="btn btn-sm @(item.IsActive == true ? "btn-secondary" : "btn-success")" title="Durumu Değiştir">
                                        <i class="fas @(item.IsActive == true ? "fa-toggle-on" : "fa-toggle-off")"></i>
                                    </button>
                                }
                                <a href="/Admin/AdminAppointment/Edit/@item.Appointmentid" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="/Admin/AdminAppointment/Delete/@item.Appointmentid" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>