@{
    ViewBag.Title = "Doktor Paneli";
    Layout = "~/Areas/Doctor/Views/Shared/_DoctorLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Hoşgeldiniz, Dr. @ViewBag.DoctorName</h1>
</div>

@if (!string.IsNullOrEmpty(ViewBag.Error as string))
{
    <div class="alert alert-warning">@ViewBag.Error</div>
}

<div class="row">
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Bugünkü Randevular</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TodayCount</div>
                    </div>
                    <div class="col-auto"><i class="fas fa-calendar-day fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Yaklaşan Randevular</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.UpcomingCount</div>
                    </div>
                    <div class="col-auto"><i class="fas fa-clock fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Toplam Randevu</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalCount</div>
                    </div>
                    <div class="col-auto"><i class="fas fa-calendar-check fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-success">Hızlı Erişim</h6>
            </div>
            <div class="card-body">
                <a href="/Doctor/DoctorDashboard/TodayAppointments" class="btn btn-success btn-lg mr-3 mb-2">
                    <i class="fas fa-calendar-day mr-2"></i>Bugünün Randevuları
                </a>
                <a href="/Doctor/DoctorDashboard/MyAppointments" class="btn btn-primary btn-lg mb-2">
                    <i class="fas fa-list mr-2"></i>Tüm Randevularım
                </a>
            </div>
        </div>
    </div>
</div>